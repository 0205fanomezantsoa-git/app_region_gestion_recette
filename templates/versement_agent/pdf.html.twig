<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Versement Agent - Régisseur</title>

    <style>

        body{
            font-family: Arial, sans-serif;
            font-size:12px;
            color:#000;
            margin:20px;
        }

        .header{
            text-align:center;
            margin-bottom:20px;
        }

        .logo{
            width:90px;
        }

        .logo-center{
            width:110px;
            margin:10px auto;
            display:block;
        }

        .title{
            text-align:center;
            font-size:18px;
            font-weight:bold;
            margin-top:10px;
            margin-bottom:20px;
            border-bottom:2px solid #000;
            padding-bottom:10px;
        }

        .box{
            border:1px solid #000;
            padding:12px;
            margin-bottom:15px;
        }

        .section-title{
            font-weight:bold;
            margin-bottom:8px;
            font-size:14px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:15px;
        }

        table, th, td{
            border:1px solid #000;
        }

        th, td{
            padding:6px;
            text-align:center;
        }

        th{
            background:#eaeaea;
        }

        .success{
            color:green;
            font-weight:bold;
        }

        .danger{
            color:red;
            font-weight:bold;
        }

        .footer{
            margin-top:40px;
            text-align:right;
        }

    </style>
</head>

<body>

<!-- HEADER LOGOS -->

<div class="header">
    <!-- logo centre -->
    <img src="{{ absolute_url(asset('assets/images/logos/logo_centre.png')) }}"
         class="logo-center">
    <!-- logo gauche -->
    <img src="{{ absolute_url(asset('assets/images/logos/logo.jpeg')) }}"
         class="logo"  style="
            position:absolute;
            left:0;
            top:0;
            width:90px;
        ">

</div>

<div class="title">
    VERSEMENT AGENT → RÉGISSEUR
</div>

<!-- Résumé -->

<div class="box">

    <div class="section-title">RÉSUMÉ DU VERSEMENT</div>

    Montant versé :
    <strong>{{ versement.montant }} Ar</strong><br><br>

    Écart :
    <strong>{{ versement.ecart ?? 0 }} Ar</strong><br><br>

    Type :
    {{ versement.typeVersement }}<br><br>

    Date :
    {{ versement.date|date('d/m/Y') }}

</div>

<div class="box">

    <div class="section-title">
        INFORMATIONS DES RESPONSABLES
    </div>

    <table style="width:100%; border:none;">

        <tr style="border:none;">

            <!-- AGENT -->
            <td style="width:50%; border:none; vertical-align:top; padding-right:20px;">

                <strong>AGENT CONCERNÉ</strong>

                <br><br>

                Nom :
                {{ agent.nom }}

                <br><br>

                Solde :
                {{ agent.portefeuille }} Ar

            </td>

            <!-- REGISSEUR -->
            <td style="width:50%; border:none; vertical-align:top;">

                <strong>RÉGISSEUR CONCERNÉ</strong>

                <br><br>

                Nom :
                {{ regisseur.nom }}

                <br><br>

                Solde :
                {{ regisseur.portefeuille }} Ar

            </td>

        </tr>

    </table>

</div>

<!-- CARNET -->

<div class="box">

    <div class="section-title">CARNET DE QUITTANCE</div>

    N° :
    {{ versement.quittances|first.carnetQuittance.idCarnet ?? 'Non défini' }}

</div>

<!-- QUITTANCES -->

<div class="section-title">
    LISTE DES QUITTANCES
</div>

<table>

    <thead>
        <tr>
            <th>#</th>
            <th>N°</th>
            <th>Date</th>
            <th>Client</th>
            <th>Produit</th>
            <th>Qté</th>
            <th>Montant</th>
            <th>Statut</th>
        </tr>
    </thead>

    <tbody>

    {% set total = 0 %}

    {% for q in versement.quittances %}

        {% set total = total + q.montantTotal %}

        <tr>
            <td>{{ loop.index }}</td>
            <td>{{ q.numQuittance }}</td>
            <td>{{ q.dateUtilisation|date('d/m/Y') }}</td>
            <td>{{ q.nomClient }}</td>
            <td>{{ q.produit.nomProduit }}</td>
            <td>{{ q.quantite }}</td>
            <td>{{ q.montantTotal }} Ar</td>
            <td>
                {% if q.statut == 'versé' %}
                    <span class="success">VERSÉ</span>
                {% else %}
                    <span class="danger">{{ q.statut }}</span>
                {% endif %}
            </td>
        </tr>

    {% else %}
        <tr>
            <td colspan="8">Aucune quittance</td>
        </tr>
    {% endfor %}

    </tbody>

    <tfoot>
        <tr>
            <th colspan="6">TOTAL</th>
            <th colspan="2">{{ total }} Ar</th>
        </tr>
    </tfoot>

</table>

<!-- SIGNATURE -->

<div class="footer">

    Fait le : {{ "now"|date("d/m/Y") }}

    <br><br><br>

    Signature & Cachet

    <br><br><br>

    ________________________

</div>

</body>
</html>
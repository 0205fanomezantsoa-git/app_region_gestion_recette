{% extends "base.html.twig" %}

{% block body %}

<div class="container-fluid py-3">

    <div class="card shadow border-0">

        <div class="card-body" style="max-height: 600px; overflow-y: auto;">

            <!-- TITRE -->
            <div class="mb-4">
                <h3 class="fw-bold text-primary">
                    💰 Ajouter un versement Agent → Régisseur
                </h3>
                <small class="text-muted">
                    Remplissez les informations du versement ci-dessous
                </small>
            </div>
            <!-- FORM CARD -->
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    {{ form_start(form) }}
                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_row(form.agent) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.regisseur) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.montant) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.date) }}
                        </div>
                        <div class="col-md-12">
                            {{ form_row(form.typeVersement) }}
                        </div>
                    </div>
                    <hr class="my-4">
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}